# Vue3 frontend environment example.
# Copy to .env.development.local (gitignored) and fill real values for local dev.
# Never commit real credentials. Only placeholder values live here.

# Backend dev proxy target (vite dev server proxies /api -> this origin).
VITE_PROXY_TARGET=http://127.0.0.1:9090

# API base path used by axios (requests go through /api proxy in dev).
VITE_API_BASE_URL=/api

# Agent chat streaming endpoint (relative to VITE_API_BASE_URL).
VITE_AGENT_CHAT_ENDPOINT=/agent/chat/stream

# Agent chat mock mode: true = use local mock stream, false = call real endpoint.
VITE_AGENT_CHAT_MOCK=true

# Demo login prefill. Set VITE_USE_DEMO_LOGIN=true to prefill the login form
# with VITE_DEMO_MOBILE / VITE_DEMO_PASSWORD. Keep this OFF for production builds.
# Leave values empty here; set real demo creds only in your gitignored .env.*.local.
VITE_USE_DEMO_LOGIN=false
VITE_DEMO_MOBILE=
VITE_DEMO_PASSWORD=
